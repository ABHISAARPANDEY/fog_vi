# Copy to backend/.env and adjust as needed.

# --- Server ---
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Model / inference ---
# Swap for yolov8s.pt or yolov8m.pt for higher accuracy (slower).
MODEL_NAME=yolov8n.pt
CONFIDENCE=0.4
IOU=0.5
TRACKER=bytetrack.yaml
# auto | cpu | cuda | mps   (auto picks cuda -> mps -> cpu)
DEVICE=auto
IMGSZ=640
# Cap frames for quick demos (0 = process the whole video).
MAX_FRAMES=0

# --- Proximity / danger detection ---
# Vehicle box-height / frame-height above DANGER_RATIO => "too close" (red alert);
# above CAUTION_RATIO => "close" (amber). Lower the values to trigger sooner.
DANGER_RATIO=0.5
CAUTION_RATIO=0.32

# --- Fog enhancement defaults ---
ENABLE_CLAHE=true
ENABLE_GAMMA=true
GAMMA_VALUE=1.2
ENABLE_HIST_EQ=true
ENABLE_SHARPEN=true

# --- Limits ---
MAX_UPLOAD_MB=500
